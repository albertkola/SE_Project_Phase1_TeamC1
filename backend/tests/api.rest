PATCH {{host}}/api/users/me
Authorization: Bearer {{driverToken}}
Content-Type: {{contentType}}

{ "role": "admin" }

### PATCH /api/users/me — INVALID (tries to change email)
PATCH {{host}}/api/users/me
Authorization: Bearer {{driverToken}}
Content-Type: {{contentType}}

{ "email": "new@test.com" }

# ──────────────────────────────────────────────────────────────────────────
# TRIPS
# ──────────────────────────────────────────────────────────────────────────

### POST /api/trips — VALID (driver)
# @name createTrip
POST {{host}}/api/trips
Authorization: Bearer {{driverToken}}
Content-Type: {{contentType}}

{
  "departure_city": "Tirana",
  "destination_city": "Durrës",
  "departure_date": "2026-12-01",
  "departure_time": "08:00",
  "total_seats": 4,
  "price_per_seat": 500,
  "pickup_points": [
    { "location_name": "Skanderbeg Square", "pickup_time": "07:55" },
    { "location_name": "21 Dhjetori",       "pickup_time": "07:45" }
  ]
}

###
@tripId = {{createTrip.response.body.data.trip.trip_id}}
@pickupId = {{createTrip.response.body.data.trip.pickup_points.0.pickup_id}}

### POST /api/trips as passenger — INVALID (403)
POST {{host}}/api/trips
Authorization: Bearer {{passengerToken}}
Content-Type: {{contentType}}

{
  "departure_city": "Tirana", "destination_city": "Durrës",
  "departure_date": "2026-12-01", "departure_time": "08:00",
  "total_seats": 4, "price_per_seat": 500,
  "pickup_points": [{ "location_name": "X", "pickup_time": "07:00" }]
}

### POST /api/trips — INVALID (same cities, past date, 9 seats, 0 pickups)
POST {{host}}/api/trips
Authorization: Bearer {{driverToken}}
Content-Type: {{contentType}}

{
  "departure_city": "Tirana", "destination_city": "tirana",
  "departure_date": "2020-01-01", "departure_time": "08:00",
  "total_seats": 9, "price_per_seat": -1, "pickup_points": []
}

### GET /api/trips
GET {{host}}/api/trips
Authorization: Bearer {{passengerToken}}

### GET /api/trips with filters
GET {{host}}/api/trips?origin=Tirana&date=2026-12-01&maxPrice=1000
Authorization: Bearer {{passengerToken}}

### GET /api/trips with bad date
GET {{host}}/api/trips?date=not-a-date
Authorization: Bearer {{passengerToken}}

### GET /api/trips/:id
GET {{host}}/api/trips/{{tripId}}
Authorization: Bearer {{passengerToken}}

### GET /api/trips/:id — not found
GET {{host}}/api/trips/9999
Authorization: Bearer {{passengerToken}}

### GET /api/trips/driver/me
GET {{host}}/api/trips/driver/me
Authorization: Bearer {{driverToken}}

### GET /api/trips/driver/me as passenger — 403
GET {{host}}/api/trips/driver/me
Authorization: Bearer {{passengerToken}}

### PATCH /api/trips/:id — VALID (no bookings yet)
PATCH {{host}}/api/trips/{{tripId}}
Authorization: Bearer {{driverToken}}
Content-Type: {{contentType}}

{ "price_per_seat": 600 }

### PATCH /api/trips/:id — wrong role (403)
PATCH {{host}}/api/trips/{{tripId}}
Authorization: Bearer {{passengerToken}}
Content-Type: {{contentType}}

{ "price_per_seat": 700 }

### PATCH /api/trips/:id/cancel — wrong role (403)
PATCH {{host}}/api/trips/{{tripId}}/cancel
Authorization: Bearer {{passengerToken}}

