# ──────────────────────────────────────────────────────────────────────────
# ADMIN
# (1) Promote a user manually:
#     docker exec -it hopin-postgres psql -U user -d hopin \
#       -c "UPDATE users SET role='admin' WHERE email='admin@test.com';"
# (2) Re-login that user to mint an admin JWT.
# ──────────────────────────────────────────────────────────────────────────

### Login admin (after manual promotion)
# @name loginAdmin
POST {{host}}/api/auth/login
Content-Type: {{contentType}}

{ "email": "admin@test.com", "password": "hopin12345" }

###
@adminToken = {{loginAdmin.response.body.data.token}}

